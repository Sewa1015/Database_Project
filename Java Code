    public void createTables()
    {
        try
        {
            Statement stmt = conn.createStatement();

            // Student table
            stmt.execute("CREATE TABLE IF NOT EXISTS Student (" +
                         "student_id INT PRIMARY KEY, name VARCHAR(100), email VARCHAR(100), contact VARCHAR(20))");

            // Tutor table
            stmt.execute("CREATE TABLE IF NOT EXISTS Tutor (" +
                         "tutor_id INT PRIMARY KEY, name VARCHAR(100), expertise VARCHAR(100), contact VARCHAR(20), rating DECIMAL(2,1))");

            // Course table
            stmt.execute("CREATE TABLE IF NOT EXISTS Course (" +
                         "course_id INT PRIMARY KEY, title VARCHAR(100), description TEXT, tutor_id INT," +
                         "FOREIGN KEY(tutor_id) REFERENCES Tutor(tutor_id))");

            // Lesson table
            stmt.execute("CREATE TABLE IF NOT EXISTS Lesson (" +
                         "lesson_id INT PRIMARY KEY, title VARCHAR(100), content TEXT, course_id INT," +
                         "FOREIGN KEY(course_id) REFERENCES Course(course_id))");

            // Enrollment table
            stmt.execute("CREATE TABLE IF NOT EXISTS Enrollment (" +
                         "enrollment_id INT PRIMARY KEY, student_id INT, course_id INT, enrollment_date DATE," +
                         "FOREIGN KEY(student_id) REFERENCES Student(student_id)," +
                         "FOREIGN KEY(course_id) REFERENCES Course(course_id))");

            // Feedback table
            stmt.execute("CREATE TABLE IF NOT EXISTS Feedback (" +
                         "feedback_id INT PRIMARY KEY, student_id INT, lesson_id INT, tutor_id INT, rating INT, comments TEXT," +
                         "FOREIGN KEY(student_id) REFERENCES Student(student_id)," +
                         "FOREIGN KEY(lesson_id) REFERENCES Lesson(lesson_id)," +
                         "FOREIGN KEY(tutor_id) REFERENCES Tutor(tutor_id))");

            System.out.println("Tables created successfully!");
            stmt.close();
        } catch (SQLException e) { e.printStackTrace(); }
    }
    
